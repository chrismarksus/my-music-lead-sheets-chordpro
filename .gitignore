# OS / editor cruft
.DS_Store
Thumbs.db
*~
*.bak
*.swp
.claude/

# Node tooling (CI lint script dependencies)
node_modules/

# Generated site build (built by CI, deployed to GitHub Pages, never committed)
_site/

# Spotify API credentials (see scripts/fetch-spotify-links.js), never committed
.env

# Transient review output from fetch-spotify-links.js / spotify-status-report.js,
# regenerated each run (data/spotify-links.json itself IS committed — it's the build input
# for build-site.js). spotify-status.html is a local maintenance dashboard, never published.
data/artist-suggestions.md
data/spotify-links.previous.json
data/spotify-status.html

# Regenerated each run of scripts/detect-keys.js — a review queue for songs it couldn't
# confidently guess a {key:} for, never a source of truth (see scripts/detect-keys.js).
data/key-suggestions.md
